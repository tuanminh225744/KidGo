  type        string    // Always 'Point'
  coordinates number[]  // [longitude, latitude]
}

Type PlannedRoute {
  pickupAddress      string
  pickupCoords       Point
  dropoffAddress     string
  dropoffCoords      Point
  waypoints          Point[]
  estimatedDuration  int     // phút
  estimatedDistance  float   // km
}
*/
